<div class="scan-wrapper">

  <!-- ── FILE INFO BAR (below nav, has chips + export/reset) ── -->
  <div class="file-info-bar">
    <div class="file-info-bar__left">
      <span class="file-info-bar__name"><%= fileName || 'Picklist' %></span>

      <% if (columnConfig && (columnConfig.major.length || columnConfig.minor.length)) { %>
        <span class="file-info-bar__sep">—</span>
        <% columnConfig.major.forEach(col => { %>
          <% if (firstRowData[col] !== undefined) { %>
            <span class="fib-chip fib-chip--major">
              <span class="fib-chip__key"><%= col %>:</span>
              <%= firstRowData[col] %>
            </span>
          <% } %>
        <% }) %>
        <% columnConfig.minor.forEach(col => { %>
          <% if (firstRowData[col] !== undefined) { %>
            <span class="fib-chip fib-chip--minor">
              <span class="fib-chip__key"><%= col %>:</span>
              <%= firstRowData[col] %>
            </span>
          <% } %>
        <% }) %>
      <% } %>
    </div>

    <div class="file-info-bar__actions">
      <a href="/picklist/export" class="btn btn--sm btn--outline" target="_blank">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Export
      </a>
      <form action="/picklist/reset" method="POST" onsubmit="return confirm('Reset all scan counts? This cannot be undone.');" style="display:inline;">
        <button class="btn btn--sm btn--danger" type="submit">Reset</button>
      </form>
    </div>
  </div>

  <!-- ── STATS + DONUT ROW ── -->
  <div class="stats-bar">
    <div class="stat-pill">
      <span class="stat-pill__label">Expected</span>
      <span id="stat-expected" class="stat-pill__val"><%= stats.totalExpected %></span>
    </div>
    <div class="stat-pill">
      <span class="stat-pill__label">Scanned</span>
      <span id="stat-done" class="stat-pill__val stat-pill__val--done"><%= stats.totalScanned %></span>
    </div>
    <div class="stat-pill">
      <span class="stat-pill__label">Remaining</span>
      <span id="stat-remaining" class="stat-pill__val"><%= stats.totalRemaining %></span>
    </div>
    <div class="stat-pill <%= stats.alertCount > 0 ? 'stat-pill--alert' : '' %>">
      <span class="stat-pill__label">Alerts</span>
      <span id="stat-alerts" class="stat-pill__val stat-pill__val--alert"><%= stats.alertCount %></span>
    </div>
    <!-- DONUT -->
    <div class="stat-pill stat-pill--donut">
      <svg id="donut-svg" width="72" height="72" viewBox="0 0 72 72">
        <!-- Background ring -->
        <circle cx="36" cy="36" r="28" fill="none" stroke="#e9ecef" stroke-width="10"/>
        <!-- Progress ring -->
        <circle
          id="donut-ring"
          cx="36" cy="36" r="28"
          fill="none"
          stroke="#16a34a"
          stroke-width="10"
          stroke-linecap="round"
          stroke-dasharray="0 175.93"
          transform="rotate(-90 36 36)"
        />
        <!-- Percent text -->
        <text
          id="donut-pct-text"
          x="36" y="41"
          text-anchor="middle"
          font-size="13"
          font-weight="700"
          fill="#212529"
          font-family="Syne, sans-serif"
        ><%= stats.progressPct %>%</text>
      </svg>
    </div>
  </div>

  <!-- ── SCANNER INPUT ── -->
  <div class="scanner-row">
    <div class="scanner-block" id="scanner-block">
      <div class="scanner-indicator" id="scan-indicator"></div>
      <input
        id="scan-input"
        class="scanner-input"
        placeholder="Scan or type barcode..."
        autocomplete="off"
        autofocus
      />
      <div class="scanner-status" id="scanner-status">Ready</div>
    </div>

    <div class="unscan-toggle" id="unscan-toggle" title="Enable to remove items when scanned">
      <span class="unscan-toggle__label">Unscan Mode</span>
      <button
        type="button"
        class="toggle-switch"
        id="unscan-btn"
        role="switch"
        aria-checked="false"
        onclick="toggleUnscanMode()"
      >
        <span class="toggle-switch__thumb"></span>
      </button>
    </div>
  </div>

  <!-- ── UNSCAN BANNER ── -->
  <div id="unscan-banner" class="unscan-banner" style="display:none;">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/>
      <path d="M12 8v4l2 2"/>
    </svg>
    <span>Unscan Mode is <strong>ON</strong> — scanning will remove one unit instead of adding</span>
    <button type="button" onclick="toggleUnscanMode()" class="unscan-banner__close">Turn Off</button>
  </div>

  <!-- ── ALERT BANNER ── -->
  <div id="alert-banner" class="scan-alert" style="display:none;">
    <span class="scan-alert__icon">!</span>
    <span id="alert-message"></span>
  </div>

  <!-- ── TABLE ── -->
  <div class="table-container">
    <table class="picklist-table">
      <thead>
        <tr>
          <th class="col-code">Code</th>
          <th class="col-num">Expected</th>
          <th class="col-num">Scanned</th>
          <th class="col-num">Remaining</th>
          <th class="col-status">Status</th>
        </tr>
      </thead>
      <tbody id="picklist-tbody"></tbody>
    </table>
  </div>

</div>

<!-- INITIAL DATA -->
<script>
  window.__INIT__ = {
    picklist: <%- JSON.stringify(picklist) %>,
    extra:    <%- JSON.stringify(extra) %>,
    stats:    <%- JSON.stringify(stats) %>,
  };
</script>

<script src="/js/scanner.js"></script>
