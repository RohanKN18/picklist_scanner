# MongoDB Atlas connection string (required)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/picklist_db?retryWrites=true&w=majority

# Session secret — use a long random string in production
SESSION_SECRET=change_this_to_a_long_random_string

# Server port (Render sets this automatically)
PORT=3000

# How many days to keep old picklists (default: 30)
PICKLIST_RETENTION_DAYS=30
